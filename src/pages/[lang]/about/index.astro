---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageLead from "../../../components/PageLead.astro";
import { isLanguage } from "../../../lib/i18n";
import { languages } from "../../../config/site";
import { siteCopy } from "../../../data/copy";

export function getStaticPaths() {
  return languages.map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;

if (!lang || !isLanguage(lang)) {
  return Astro.redirect("/en/about/");
}

const copy = siteCopy[lang];
---

<BaseLayout title={`${copy.pages.about.title} | PingPongTech`} description={copy.pages.about.body}>
  <PageLead {...copy.pages.about} />
  <section class="shell article-layout prose-block">
    {copy.aboutParagraphs.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
  </section>
</BaseLayout>
