---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ContentCard from "../../components/ContentCard.astro";
import { getLocalizedSlug, isLanguage, localizePath, getTranslatedEntries } from "../../lib/i18n";
import { languages } from "../../config/site";
import { siteCopy } from "../../data/copy";

export function getStaticPaths() {
  return languages.map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;

if (!lang || !isLanguage(lang)) {
  return Astro.redirect("/en/");
}

const copy = siteCopy[lang].home;
const common = siteCopy[lang].common;
const featuredArticles = (await getTranslatedEntries("articles", lang)).slice(0, 3);
const featuredTopics = (await getTranslatedEntries("topics", lang)).slice(0, 4);
const featuredResources = (await getTranslatedEntries("resources", lang)).slice(0, 2);
---

<BaseLayout title={`PingPongTech | ${copy.heroEyebrow}`} description={copy.heroBody}>
  <section class="hero shell">
    <div class="hero-copy" data-reveal="left" style="--reveal-delay: 0ms;">
      <p class="eyebrow">{copy.heroEyebrow}</p>
      <h1>{copy.heroTitle}</h1>
      <p class="hero-body">{copy.heroBody}</p>
      <div class="hero-actions">
        <a class="button button-primary" href={localizePath(lang, "articles")}>{copy.heroPrimary}</a>
        <a class="button button-secondary" href={localizePath(lang, "topics")}>{copy.heroSecondary}</a>
      </div>
    </div>
    <div class="hero-panel" data-reveal="right" style="--reveal-delay: 120ms;">
      <div class="hero-visual">
        <img src="/img/hero-signal.svg" alt="Abstract multilingual editorial signal illustration" loading="eager" data-parallax />
      </div>
      <div class="hero-panel-copy">
        <p class="eyebrow">{copy.heroPanelEyebrow}</p>
        <h2>{copy.heroPanelTitle}</h2>
        <p>{copy.heroPanelBody}</p>
        <div class="translation-pills compact">
          {copy.heroPanelPills.map((pill) => (
            <span class="translation-pill active">{pill}</span>
          ))}
        </div>
        <div class="signal-metrics">
          {copy.heroMetrics.map((metric) => (
            <div class="signal-metric">
              <strong>{metric.value}</strong>
              <span>{metric.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="shell section-grid">
    <SectionHeading eyebrow={copy.coreTopicsEyebrow} title={copy.coreTopicsTitle} body={copy.coreTopicsBody} delay={0} />
    <div class="card-grid">
      {featuredTopics.map((topic, index) => (
        <ContentCard href={`/${lang}/topics/${getLocalizedSlug(topic.slug)}/`} title={topic.data.title} description={topic.data.description} meta={topic.data.focus.join(" · ")} delay={index * 90} />
      ))}
    </div>
  </section>

  <section class="shell section-grid">
    <SectionHeading eyebrow={copy.featuredEyebrow} title={copy.featuredTitle} body={copy.featuredBody} delay={0} />
    <div class="card-grid">
      {featuredArticles.map((article, index) => (
        <ContentCard
          href={`/${lang}/articles/${getLocalizedSlug(article.slug)}/`}
          title={article.data.title}
          description={article.data.description}
          meta={`${article.data.category} · ${article.data.readingTime}`}
          delay={index * 90}
        />
      ))}
    </div>
  </section>

  <section class="shell trust-strip">
    <SectionHeading title={copy.trustTitle} body={copy.trustBody} delay={0} />
    <div class="trust-points">
      {copy.trustPoints.map((point, index) => (
        <div class="trust-point" data-reveal="up" style={`--reveal-delay: ${index * 90}ms;`}>{point}</div>
      ))}
    </div>
  </section>

  <section class="shell split-callout">
    <div data-reveal="left" style="--reveal-delay: 0ms;">
      <SectionHeading eyebrow={copy.resourcesEyebrow} title={copy.resourcesTitle} body={copy.resourcesBody} />
      <a class="button button-secondary" href={localizePath(lang, "resources")}>{common.browseResources}</a>
    </div>
    <div class="resource-stack" data-reveal="right" style="--reveal-delay: 120ms;">
      {featuredResources.map((resource, index) => (
        <ContentCard href={`/${lang}/resources/${getLocalizedSlug(resource.slug)}/`} title={resource.data.title} description={resource.data.description} meta={resource.data.resourceType} delay={index * 90} />
      ))}
    </div>
  </section>

  <section class="shell about-callout" data-reveal="up" style="--reveal-delay: 0ms;">
    <SectionHeading title={copy.aboutTitle} body={copy.aboutBody} />
    <a class="button button-primary" href={localizePath(lang, "about")}>{common.viewAbout}</a>
  </section>
</BaseLayout>
