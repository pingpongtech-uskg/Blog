---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ContentCard from "../../../components/ContentCard.astro";
import PageLead from "../../../components/PageLead.astro";
import { getLocalizedSlug, getTranslatedEntries, isLanguage } from "../../../lib/i18n";
import { languages } from "../../../config/site";
import { siteCopy } from "../../../data/copy";

export function getStaticPaths() {
  return languages.map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;

if (!lang || !isLanguage(lang)) {
  return Astro.redirect("/en/topics/");
}

const topics = await getTranslatedEntries("topics", lang);
const copy = siteCopy[lang].pages.topics;
---

<BaseLayout title={`${copy.title} | PingPongTech`} description={copy.body}>
  <PageLead {...copy} />
  <section class="shell card-grid">
    {topics.map((topic) => (
      <ContentCard href={`/${lang}/topics/${getLocalizedSlug(topic.slug)}/`} title={topic.data.title} description={topic.data.description} meta={topic.data.focus.join(" · ")} />
    ))}
  </section>
</BaseLayout>
