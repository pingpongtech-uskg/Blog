---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LanguageSwitcher from "../../../components/LanguageSwitcher.astro";
import TranslationStatus from "../../../components/TranslationStatus.astro";
import { getEntryLanguageLinks, getLocalizedSlug, getTranslationState } from "../../../lib/i18n";

export async function getStaticPaths() {
  const resources = await getCollection("resources", ({ data }) => !data.draft);
  return resources.map((entry) => ({
    params: { lang: entry.data.lang, slug: getLocalizedSlug(entry.slug) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const translationState = await getTranslationState("resources", entry.data.translationKey);
const languageLinks = await getEntryLanguageLinks("resources", entry.data.translationKey);
---

<BaseLayout title={`${entry.data.title} | PingPongTech`} description={entry.data.description}>
  <article class="shell article-layout prose-block">
    <p class="eyebrow">{entry.data.resourceType}</p>
    <h1>{entry.data.title}</h1>
    <p class="article-summary">{entry.data.description}</p>
    <LanguageSwitcher currentLang={entry.data.lang} links={languageLinks} />
    <TranslationStatus currentLang={entry.data.lang} available={translationState.available} missing={translationState.missing} />
    <Content />
    {entry.data.ctaHref && entry.data.ctaLabel && (
      <p><a class="button button-primary" href={entry.data.ctaHref}>{entry.data.ctaLabel}</a></p>
    )}
  </article>
</BaseLayout>
