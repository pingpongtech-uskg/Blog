---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ContentCard from "../../../components/ContentCard.astro";
import PageLead from "../../../components/PageLead.astro";
import { getLocalizedSlug, getTranslatedEntries, isLanguage } from "../../../lib/i18n";
import { languages } from "../../../config/site";
import { siteCopy } from "../../../data/copy";

export function getStaticPaths() {
  return languages.map((lang) => ({
    params: { lang }
  }));
}

const { lang } = Astro.params;

if (!lang || !isLanguage(lang)) {
  return Astro.redirect("/en/resources/");
}

const resources = await getTranslatedEntries("resources", lang);
const copy = siteCopy[lang].pages.resources;
---

<BaseLayout title={`${copy.title} | PingPongTech`} description={copy.body}>
  <PageLead {...copy} />
  <section class="shell card-grid">
    {resources.map((resource) => (
      <ContentCard href={`/${lang}/resources/${getLocalizedSlug(resource.slug)}/`} title={resource.data.title} description={resource.data.description} meta={resource.data.resourceType} />
    ))}
  </section>
</BaseLayout>
